{
  "schemaVersion": 1,
  "engine": "krkrsdl2-web",
  "compatibilityMode": "phase1-common-cn",
  "scope": "一期只做国内游戏最常见、最影响启动和基础流程的插件",
  "resolution": {
    "scriptExtension": ".dll",
    "nativeSideModuleExtension": ".so",
    "searchPaths": [
      "/plugin",
      "/system",
      "/"
    ],
    "unknownPluginPolicy": "explicit-error"
  },
  "plugins": [
