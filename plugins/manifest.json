      "license": "to-be-confirmed",
      "implementationType": "web-shim",
      "compatLevel": "C",
      "priority": "P0",
      "phase": 1,
      "reason": "国内游戏常用菜单插件；直接影响标题菜单、系统菜单和快捷键。",
