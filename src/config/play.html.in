      由 Kirikiri SDL2 提供动力
    </a>

    <div id="statusbar_container">
      <div id="statusbar">
        <div class="spinner" id='spinner'></div>
        <div style="margin-left: 50px;">
          <div class="emscripten" id="status">下载中…</div>
          <progress value="0" max="100" id="progress" hidden=1></progress>
        </div>
      </div>
    </div>

    <div class="emscripten_border">
      <canvas class="emscripten" id="canvas" oncontextmenu="event.preventDefault()" tabindex=-1></canvas>
    </div>

    <script type='text/javascript'>
      var statusElement = document.getElementById('status');
      var progressElement = document.getElementById('progress');
      var spinnerElement = document.getElementById('spinner');

      var Module = {
        arguments: ['/data.xp3'],
        preRun: [],
        postRun: [],
        print: (function() {
          return function(text) {
            console.log(text);
          };
        })(),
        printErr: function(text) {
          if (arguments.length > 1) text = Array.prototype.slice.call(arguments).join(' ');
          console.error(text);
        },
        canvas: (function() {
          var canvas = document.getElementById('canvas');

          // As a default initial behavior, pop up an alert when webgl context is lost. To make your
          // application robust, you may want to override this behavior before shipping!
          // See http://www.khronos.org/registry/webgl/specs/latest/1.0/#5.15.2
          canvas.addEventListener("webglcontextlost", function(e) { alert('WebGL 上下文丢失，请刷新页面重试。'); e.preventDefault(); }, false);

          return canvas;
        })(),
        setStatus: function(text) {
          if (!Module.setStatus.last) Module.setStatus.last = { time: Date.now(), text: '' };
          if (text === Module.setStatus.last.text) return;
          var m = text.match(/([^(]+)\((\d+(\.\d+)?)\/(\d+)\)/);
          var now = Date.now();
          if (m && now - Module.setStatus.last.time < 30) return; // 进度更新太频繁则跳过本帧
          Module.setStatus.last.time = now;
          Module.setStatus.last.text = text;
          if (m) {
            text = m[1];
            progressElement.value = parseInt(m[2])*100;
            progressElement.max = parseInt(m[4])*100;
            progressElement.hidden = false;
            spinnerElement.hidden = false;
          } else {
            progressElement.value = null;
            progressElement.max = null;
            progressElement.hidden = true;
            if (!text) spinnerElement.style.display = 'none';
          }
          if (text == '') {
            statusElement.innerHTML = '';
            document.getElementById('statusbar').hidden = true;
          } else {
            statusElement.innerHTML = text + '<br />';
            document.getElementById('statusbar').hidden = false;
          }
        },
        totalDependencies: 0,
        monitorRunDependencies: function(left) {
          this.totalDependencies = Math.max(this.totalDependencies, left);
          Module.setStatus(left ? '准备中… (' + (this.totalDependencies-left) + '/' + this.totalDependencies + ')' : '全部下载完成。');
        }
      };
      Module.setStatus('下载中…');
      window.onerror = function(event) {
        // TODO: 不对模拟无限循环或 exitStatus 这类正常事件报警
        Module.setStatus('错误：' + event.split('\n')[0] + '（详见 JavaScript 控制台）');
        spinnerElement.style.display = 'none';
        Module.setStatus = function(text) {
          if (text) Module.printErr('[异常后状态] ' + text);
        };
      };
    </script>
    <script>
      // 规避 iframe 焦点问题
      // https://github.com/emscripten-core/emscripten/pull/7631
      document.getElementById('canvas').addEventListener('mouseenter', function(e) { window.focus() });
      document.getElementById('canvas').addEventListener('click', function(e) { window.focus() });

      function onLoadMainJs() {
        instantiate_krkrsdl2_module(Module);
      }

      function loadMainJs() {
        var script = document.createElement('script');
        script.src = "@KRKRSDL2_NAME@.js";
        script.onload = onLoadMainJs;
        document.body.appendChild(script);
      }

      function xhrDownloadFile(url, dest)
      {
        _GET = {};
        if (location.search.length > 0) {
          location.search.substr(1).split('&').forEach(function(item) {
            var eq = item.indexOf('=');
            var k = eq < 0 ? item : item.substr(0, eq);
            var v = eq < 0 ? '' : item.substr(eq + 1);
            try { k = decodeURIComponent(k); } catch(e) {}
            try { v = decodeURIComponent(v); } catch(e) {}
            _GET[k] = v;
          });
        }

        if (_GET['data']) {
          // 允许带子目录的相对路径（含中文等 Unicode 文件名，如 games/中文.xp3），
          // 但拒绝路径穿越、绝对路径、协议相对 URL 和 javascript: 之类的 scheme。
          var d = _GET['data'];
          if (d.indexOf('..') === -1 && d.indexOf('//') === -1 && d.charAt(0) !== '/' && !/^[a-z][a-z0-9+.-]*:/i.test(d)) {
            url = d;
          } else {
            throw "不允许的路径";
          }
        }

        var should_invalidate_cache = false;

        var special_cache_string = "1";

        if (should_invalidate_cache) {
          special_cache_string = "" + (new Date()).getTime();
          url += ((/\?/).test(url) ? "&" : "?") + special_cache_string;
        }

        var xhr = new XMLHttpRequest();
        xhr.open('GET', url, true);
        xhr.responseType = 'arraybuffer';
        xhr.onprogress = function(event) {
          var size = -1;
          if (event.total) size = event.total;
          if (event.loaded) {
            if (!xhr.addedTotal) {
              xhr.addedTotal = true;
              if (!Module.dataFileDownloads) Module.dataFileDownloads = {};
              Module.dataFileDownloads[url] = {
                loaded: event.loaded,
                total: size
              };
            } else {
              Module.dataFileDownloads[url].loaded = event.loaded;
            }
            var total = 0;
            var loaded = 0;
            var num = 0;
            for (var download in Module.dataFileDownloads) {
              var data = Module.dataFileDownloads[download];
              total += data.total;
              loaded += data.loaded;
              num += 1;
            }
            if (Module['setStatus']) Module['setStatus']('正在下载游戏资源… (' + loaded + '/' + total + ')');
          } else if (!Module.dataFileDownloads) {
            if (Module['setStatus']) Module['setStatus']('正在下载游戏资源…');
          }
        };
        xhr.onerror = function(event) {
          console.log(xhr);
          console.log(event);
          if (Module['setStatus']) Module['setStatus']('游戏资源下载出错！');
        }
        xhr.onload = function(event) {
          if (xhr.status == 200 || xhr.status == 304 || xhr.status == 206 || (xhr.status == 0 && xhr.response)) {
            Module['FS'].writeFile(dest, new Uint8Array(xhr.response), {
              canOwn: true
            });
            if (Module['setStatus']) Module['setStatus']('');
            Module['removeRunDependency'](url);
          } else {
            console.log(xhr);
            console.log(event);
            Module.print("下载游戏资源出错，位置 " + xhr.responseURL +
              " : " + xhr.statusText + "（状态码 " + xhr.status + "）\n");
            if (Module['setStatus']) Module['setStatus']('游戏资源下载出错！');
            // 未指定游戏且默认路径也找不到：送用户回主页
            if (!_GET['data']) {
              document.getElementById('status').innerHTML = '未指定游戏，3 秒后返回游戏库…';
              setTimeout(function(){ location.href = 'index.html'; }, 3000);
            }
          }
        };
        xhr.send(null);
        Module['addRunDependency'](url);
      }

      function runWithFS() {
        Module['FS'].mkdir('/libsdl');
        Module['FS'].mkdir('/libsdl/krkrsdl2');

        // 下载 data.xp3（或通过 ?data= 指定的文件）
        xhrDownloadFile('data.xp3', '/data.xp3');

        // 初始化 IDBFS 用于存档数据。按游戏隔离 root，避免不同游戏存档
        // 在 IndexedDB 里互相覆盖（挂载点不变，引擎写存档路径不受影响）。
        var gameId = (_GET['data'] || 'data.xp3').replace(/[^A-Za-z0-9._-]/g, '_');
        Module['FS'].mount(Module['IDBFS'], { root: gameId }, '/libsdl/krkrsdl2');

        Module['FS'].syncfs(true, function (err) {
          Module['removeRunDependency']('savedata');
        });
        Module['addRunDependency']('savedata');
      }
      Module['preRun'].push(runWithFS);

      if (!window.WebAssembly) {
        // 当前浏览器不支持 WebAssembly，先加载 .wasm.js 这个 JavaScript 回退实现，
        // 再加载主 JS 运行时。
        var wasm2js = document.createElement('script');
        wasm2js.src = '@KRKRSDL2_NAME@.wasm.js';
        wasm2js.onload = loadMainJs;
        document.body.appendChild(wasm2js);
      } else {
        // Current browser supports Wasm, proceed with loading the main JS runtime.
        loadMainJs();
      }

    </script>
    <script>
      // 系列快捷切换器：独立于 wasm Module，只读 manifest。
      // 当前游戏有 series 且该系列 ≥2 款时显示下拉，切换即跳转。
      (function(){
        var sel = document.getElementById('seriesSwitch');
        if(!sel) return;
        function escapeHtmlLite(s){
          return String(s||'').replace(/[&<>"]/g,function(c){
            return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c];
          });
        }
        function currentDataFile(){
          var m = /(?:^|[?&])data=([^&]*)/.exec(location.search);
          if(!m) return 'data.xp3';
          try { return decodeURIComponent(m[1]); } catch(e){ return m[1]; }
        }
        var current = currentDataFile();
        fetch('api/manifest', {cache:'no-store'}).then(function(r){
          return r.ok ? r.json() : null;
        }).then(function(manifest){
          if(!manifest || !manifest.games) return;
          var list = manifest.games;
          var me = null;
          for(var i=0;i<list.length;i++){ if(list[i].file === current){ me = list[i]; break; } }
          if(!me || !me.series) return;
          var siblings = list.filter(function(g){ return g.series === me.series; });
          if(siblings.length < 2) return;
          sel.innerHTML = siblings.map(function(g){
            var isCur = g.file === current ? ' selected' : '';
            return '<option value="' + escapeHtmlLite(g.file) + '"' + isCur + '>'
              + escapeHtmlLite(g.title || g.file) + '</option>';
          }).join('');
          sel.title = me.series;
          sel.hidden = false;
        }).catch(function(){ /* 静默：不影响游戏运行 */ });
        sel.addEventListener('change', function(){
          if(sel.value) location.href = 'play.html?data=' + encodeURIComponent(sel.value);
        });
      })();
    </script>
  </body>
</html>
