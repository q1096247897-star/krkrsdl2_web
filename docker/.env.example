# krkr-web 部署配置 —— 复制为 .env 后修改
# （运行 configure.sh 可交互式生成 .env）

# 对外端口（宿主机访问端口）
PORT=8080

# 数据目录/文件的宿主路径。
# 默认相对 docker-compose.yml 所在目录（即 deploy/ 内）。
# 群晖物理机路径：游戏扫描目录与基础数据存储目录
GAMES_DIR=/volume1/game/18+
COVERS_DIR=/volume2/base/18x/krkrsdl2_web/covers
MANIFEST_FILE=/volume2/base/18x/krkrsdl2_web/manifest.json
